MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a4a2d85a031f79d48bc826866dadb256, type: 3}
  m_Name: ListOfPages
  m_EditorClassIdentifier: Assembly-CSharp::BookPages
  pages:
  - pageHeading: STORY
    pageWriting: "(In case you forget, the spirit has a fondness for erasing your
      memories) You\u2019re a mystic from a long line of carnival fortune tellers,
      your ancestors struck a deal with a soul hungry spirit, in return you get the
      power to read fortunes and make wishes come true, the spirit is linked to your
      bloodline forever and gets the chance to steal your customers souls with their
      own interpretation, they will try and read the cards negatively in order to
      kill them, if he succeeds he claims their soul. You are a 10th generation fortune
      teller and the main attraction of the carnival, known as the Trans Balkan Express.
      Due to another deal your ancestors made with the \u201COutrageously Wonderful
      Mr. Zagoo\u201D if you ever run out of customers you will burst into flames."
    pageImage: {fileID: 0}
  - pageHeading: QUICK START GUIDE
    pageWriting: "Earn more <b>favor</b> than the spirit. Each card hides a <b>theme</b>
      (Greed, Vanity, Chaos, Power), a <b>moral</b> sticker (Good, Neutral, Bad),
      and a funny <b>vignette</b>. The booth scores your words for theme weave, loose
      echo of each vignette, and fit to the customer\u2019s wealth.\n\n<b>Before you
      submit a reading:</b>\n1. Glance morals \u2014 Good cards help you; Bad cards
      help the spirit; all Neutral means your speech carries the round.\n2. Glance
      the magic meter \u2014 at FULL you win instantly.\n3. <b>Observe the customer\u2019s
      wealth</b> \u2014 study whoever waits at the tent door (or sits at your table
      after you call them in). Each patron wears one to three visual clues. <b>Rich</b>
      clues: top hat, monocle, fine suit. <b>Poor</b> clues: barrel, patched hat,
      worn spectacles. Weave their station into your reading (comfort, privilege,
      scrape, thin purse, dignity) \u2014 <b>do not name the props</b> in your fortune;
      the booth scores wealth-fit, not a costume checklist.\n4. Line up theme echoes
      in draw order (one theme batch per card).\n5. Echo each vignette loosely (image
      and appetite, not the title pasted).\n6. Stack hope words; keep harsh words out
      of your mouth.\n\n<b>Book of Wisdom:</b> From page three onward, each pasteboard
      has its own page. They start <b>locked</b> \u2014 draw a card in the tent and
      name its theme in a reading to reveal its portrait, morality, and lore here."
    pageImage: {fileID: 0}
