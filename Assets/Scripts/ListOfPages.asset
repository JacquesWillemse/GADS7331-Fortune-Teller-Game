  m_Script: {fileID: 11500000, guid: a4a2d85a031f79d48bc826866dadb256, type: 3}
  m_Name: ListOfPages
  m_EditorClassIdentifier: Assembly-CSharp::BookPages
  pages:
  - pageHeading: 1
    pageWriting: "\u2022\tYou have to identify one of the 4 themes for each card
      and make a connection between all 3, if 2 themes are repeated you must make
      a reinforcing connection. \u2022\tYou must state whether it is a morally good,
      bad or neutral reading \u2022\tIf its good the player has a judge bias, if
      its bad the spirit does \u2022\tThe player can add a value of 0 to 100 energy
      to their prediction that will influence the verdict, 100 is an automatic win.
      \u2022\tThe fortune reading of the spirit and the player must end in a statement
      referencing the themes and morality, but be twisted in a positive or negative
      direction respectively "
    pageImage: {fileID: 0}
  - pageHeading: 2
    pageWriting: b
    pageImage: {fileID: 0}
  - pageHeading: 3
    pageWriting: c
    pageImage: {fileID: 0}
